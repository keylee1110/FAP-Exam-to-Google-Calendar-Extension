{
  "manifest_version": 3,
  "name": "FAP Exam to Google Calendar",
  "version": "1.0.0",
  "description": "Automatically extract exam schedules from FPT University's FAP portal and add them to Google Calendar in one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "FPT Helper"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://fap.fpt.edu.vn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://fap.fpt.edu.vn/Exam/ScheduleExams.aspx*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "192": "icons/android-chrome-192x192.png",
    "512": "icons/android-chrome-512x512.png"
  }
}
